{
  "seed": 42,
  "device": "cuda",

  "dataset": {
    "name": "CIFAR10",
    "root": "./data/raw",
    "download": true,
    "num_classes": 10
  },

  "channel": {
    "snr_mode": "uniform",
    "snr_db": 10.0,
    "snr_min": 0.0,
    "snr_max": 20.0,
    "pt": 1.0,
    "eps": 1e-8
  },

  "sc_model": {
    "in_channels": 3,
    "base_channels": 64,
    "latent_channels": 16
  },

  "loss": {
    "name": "mse",
    "lambda_l1": 1.0,
    "lambda_msssim": 0.2
  },

  "train_sc": {
    "epochs": 200,
    "batch_size": 128,
    "lr": 0.0003,
    "weight_decay": 1e-5,
    "num_workers": 0,
    "save_dir": "./checkpoints_sc"
  },

  "downstream": {
    "model_name": "resnet50",
    "pretrained": true,
    "epochs": 30,
    "batch_size": 128,
    "lr": 0.0001,
    "weight_decay": 1e-5,
    "num_workers": 0,
    "save_dir": "./checkpoints_downstream"
  },

  "eval": {
    "batch_size": 128,
    "num_workers": 0,
    "snrs": [-5, 0, 5, 10, 15, 20],
    "save_dir": "./figures_sc_cls"
  }
}