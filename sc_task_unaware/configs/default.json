{
  "seed": 42,
  "device": "cuda",

  "dataset": {
    "name": "CIFAR10",
    "root": "../data/raw",
    "download": true
  },

  "channel": {
    "snr_mode": "uniform",
    "snr_db": 10.0,
    "snr_min": 0.0,
    "snr_max": 20.0,
    "pt": 1.0,
    "eps": 1e-8
  },

  "sc_model": {
    "in_channels": 3,
    "base_channels": 64,
    "latent_channels": 256
  },

  "loss": {
    "rec_mode": "mse",
    "lambda_rec": 1.0,
    "lambda_stru": 0.15
  },

  "structure_model": {
    "name": "dinov2_vits14",
    "img_size": 224,
    "feat_distance": "l1",
    "layer_ids": [3, 7, 11],
    "layer_weights": [0.25, 0.35, 0.40],
    "normalize_feats": true
  },

  "train_sc": {
    "epochs": 200,
    "batch_size": 128,
    "lr": 0.0003,
    "weight_decay": 1e-5,
    "num_workers": 0,
    "save_dir": "./checkpoints_sc"
  },

  "eval": {
    "batch_size": 128,
    "num_workers": 0,
    "snrs": [-5, 0, 5, 10, 15, 20],
    "save_dir": "./eval_outputs"
  }
}